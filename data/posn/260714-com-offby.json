adding:2px 7px;text-align:center;font-family:monospace\">i: 1→2</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">3</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c = 1+2 = 3</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i: 2→3</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">4</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c = 3+3 = 6</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i: 3→4</td></tr></table>c = <b>6</b> (คือ 0+1+2+3)<br>⚠️ <b>เทียบข้อก่อน: โค้ดต่างกันแค่สลับ 2 บรรทัด แต่ผลต่างกัน 10 vs 6</b>", "tr": "i เพิ่มทีหลัง → บวก 0,1,2,3 (ค่าเก่า)"}, {"layer": 2, "q": "<pre>a=[3,7,2,8]\nc=0\ni=0\nwhile i&lt;3:\n    if a[i]&lt;a[i+1]:\n        c=c+1\n    i=i+1</pre>ค่า <code>c</code>?", "ch": ["2", "3", "1", "4"], "c": "2", "ex": "<b>เทียบตัวติดกัน · ลูปหยุดที่ i &lt; 3 เพราะต้องใช้ a[i+1]</b><table style=\"border-collapse:collapse;font-size:11px;margin:5px 0\"><tr><th style=\"border:1px solid #cfe0dc;padding:2px 7px\">i</th><th style=\"border:1px solid #cfe0dc;padding:2px 7px\">เทียบ</th><th style=\"border:1px solid #cfe0dc;padding:2px 7px\">c</th></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i=0</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">3 &lt; 7 ✓</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c=1</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i=1</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">7 &lt; 2 ✗</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-
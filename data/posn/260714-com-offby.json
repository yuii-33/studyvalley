;padding:2px 7px;text-align:center;font-family:monospace\">i → 5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c=2</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">3</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">5 ✓</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i → 7</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c=3</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">4</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">7 ✓</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i → 9</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c=4</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">9 ✓</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">i → 11</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c=5</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">6</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">11 ≤ 10 ✗</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">หยุด</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">c=5</td></tr></table>c = <b>5</b>", "tr": "i = 1, 3, 5, 7, 9 เข้าลูปได้ · 11 ไม่เข้า"}, {"layer": 3, "q": "โปรแกรม A กับ B ต่างกันแค่<b>เครื่องหมายเดียว</b> · ผลลัพธ์ต่างกันเท่าไร?<div style=\"border:1px solid #cfe0dc;border-radius:6px;padding:2px 8px;margin:4px 0\"><b style=\"color:#0d7d8a\">A</b><pre>i=1\nc=0\nwhile i&lt;=5:\n    c=c+1\n    i=i+1\nprint(c)</pre></div><div style=\"border:1px solid #cfe0dc;border-radius:6px;padding:2px 8px;margin:4px 0\"><b style=\"color:#0d7d8a\">B</b><pre>i=1\nc=0\nwhile i&lt;5:\n    c=c+1\n    i=i+1\nprint(c)</pre></div>ค่า A − B เท่ากับเท่าไร?", "ch": ["1", "0", "2", "5"], "c": "1", "ex": "<b>ไล่ทั้งสองโปรแกรม</b><br><b>A</b> (i ≤ 5): i วน 1, 2, 3, 4, <b>5</b> → c = 5<br><b>B</b> (i &lt; 5): i วน 1, 2, 3, 4 → c = 4<br>A − B = 5 − 4 = <b>1</b><br>📌 <b>นี่คือกับดัก off-by-one ที่พบบ่อยที่สุด — ต่างแค่ = ตัวเดียว ผลต่าง 1 รอบ</b>", "tr": "<= รวมค่าขอบ · < ไม่รวม → ต่างกัน 1 รอบ", "deep": true}, {"layer": 3, "q": "<pre>n=5\nc=0\ni=1\nwhile i&lt;=n:\n    j=i+1\n    while j&lt;=n:\n        c=c+1\n        j=j+1\n    i=i+1</pre>ค่า <code>c</code>?", "ch": ["10", "15", "20", "25"], "c": "10", "ex": "<b>ลูปในเริ่มที่ j = i + 1 (ข้ามตัวเอง)</b><table style=\"border-collapse:collapse;font-size:11px;margin:5px 0\"><tr><th style=\"border:1px solid #cfe0dc;padding:2px 7px\">i</th><th style=\"border:1px solid #cfe0dc;padding:2px 7px\">j วน</th><th style=\"border:1px solid #cfe0dc;padding:2px 7px\">รอบ</th></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">1</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">2–5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">4</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">2</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">3–5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">3</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">3</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">4–5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">2</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">4</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">5–5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">1</td></tr><tr><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">5</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">6–5 (ไม่มี)</td><td style=\"border:1px solid #cfe0dc;padding:2px 7px;text-align:center;font-family:monospace\">0</td></tr></table>รวม 4+3+2+1+0 = <b>10</b><br><i>นี่คือการนับ \"คู่ที่ต่างกัน\" จาก 5 ตัว = C(5,2) = 10</i>", "tr": "j เริ่มที่ i+1 → นับคู่ (i, j) ที่ i < j", "deep": true}, {"layer": 3, "q": "<pre>n=5\ns=0\ni=1\nwhile i&lt;n:\n    s=s+i\n    i=i+1</pre>ค่า <code>s</code>?", "ch": ["10", "15", "5", "6"], "c": "10", "ex": "<b>เงื่อนไข i &lt; n (ไม่รวม n)</b><br>i วนได้ 1, 2, 3, 4 (ไม่ถึง 5)<br>s = 1 + 2 + 3 + 4 = <b>10</b><br>⚠️ <b>ถ้าตั้งใจบวก 1 ถึง 5 (ได้ 15) ต้องเขียน i &lt;= n</b><br>นี่คือความผิดพลาด off-by-one แบบคลาสสิก", "tr": "i < 5 หยุดที่ 4 → ไม่ได้บวก 5", "deep": true}]}